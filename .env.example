# =============================================================================
# Customer Support Resolution Agent — Environment Variables
# Copy this file to `.env` and fill in your values. Never commit `.env`.
# =============================================================================

# --- LLM Provider (required for agent reasoning) ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: override default model
# OPENAI_MODEL=gpt-4o-mini

# --- LangSmith (optional — tracing & debugging) ---
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=lsv2-your-langsmith-key-here
# LANGCHAIN_PROJECT=support-agent

# --- ChromaDB / RAG (optional overrides) ---
# CHROMA_PERSIST_DIR=./data/chroma_db
# EMBEDDING_MODEL=text-embedding-3-small

# --- FastAPI backend ---
# API_HOST=0.0.0.0
# API_PORT=8000

# --- Streamlit frontend ---
# STREAMLIT_API_URL=http://localhost:8000

# --- Governance ---
# AUDIT_LOG_PATH=./data/audit.log
# MAX_REFUND_AMOUNT_USD=500.00
